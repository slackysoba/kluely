{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kluely",
  "version": "0.1.0",
  "identifier": "com.kluely.desktop",
  "build": {
    "frontendDist": "https://kluely.vercel.app",
    "devUrl": "https://kluely.vercel.app"
  },
  "app": {
    "windows": [
      {
        "title": "Kluely",
        "width": 1100,
        "height": 800,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --use-fake-ui-for-media-stream"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
